# Plane release tag (use "stable" or a specific version like "v0.23.0")
APP_RELEASE=stable

# Application
SECRET_KEY=changeme  # Generate: openssl rand -hex 32
WEB_URL=https://plane.yourdomain
CORS_ALLOWED_ORIGINS=https://plane.yourdomain
CSRF_TRUSTED_ORIGINS=https://plane.yourdomain

# Postgres
POSTGRES_USER=plane
POSTGRES_PASSWORD=changeme  # Generate: openssl rand -hex 16
POSTGRES_DB=plane

# RabbitMQ
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=changeme  # Generate: openssl rand -hex 16
RABBITMQ_VHOST=plane

# MinIO (S3-compatible object storage)
AWS_ACCESS_KEY_ID=changeme  # Generate: openssl rand -hex 16
AWS_SECRET_ACCESS_KEY=changeme  # Generate: openssl rand -hex 32
AWS_S3_BUCKET_NAME=uploads

# Live collaboration service
LIVE_SERVER_SECRET_KEY=changeme  # Generate: openssl rand -hex 32
