# Postgres
DB_USER=n8n
DB_PASSWORD=changeme  # Generate: openssl rand -hex 16
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=n8n-db
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n

# n8n
N8N_ENCRYPTION_KEY=changeme  # Generate: openssl rand -hex 32
N8N_HOST=n8n.yourdomain
WEBHOOK_URL=https://n8n.yourdomain/

# Trigger proxy (if using task-dispatcher integration)
TRIGGER_PROXY_SECRET=changeme  # Generate: openssl rand -hex 32

# Timezone
GENERIC_TIMEZONE=America/New_York
