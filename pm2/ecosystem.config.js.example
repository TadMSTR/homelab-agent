// PM2 Ecosystem Configuration — Example
//
// PM2 manages long-running services and scheduled jobs on the AI host.
// Services fall into two categories:
//   - Always-on: daemons that run continuously (qmd, cui)
//   - Scheduled: cron jobs that run at set intervals, then stop (backups, syncs, monitors)
//
// Install PM2: npm install -g pm2
// Load this config: pm2 start ecosystem.config.js
// Save state: pm2 save
// Enable startup: pm2 startup (follow the printed command)
//
// Logs: ~/.pm2/logs/<name>-out.log, <name>-error.log
// Monitor: pm2 monit

module.exports = {
  apps: [

    // =========================================================================
    // ALWAYS-ON SERVICES
    // =========================================================================

    {
      // Semantic search MCP server (HTTP transport for multi-client access)
      // Claude Desktop uses stdio transport separately; this serves LibreChat
      // and any other HTTP MCP clients.
      name: "qmd",
      script: "/usr/bin/bash",
      args: "-c 'qmd mcp --http --port 8181'",
      env: {
        QMD_HOST: "0.0.0.0",   // Bind to all interfaces (needed if other hosts connect)
      },
      autorestart: true,        // Restart if it crashes
      max_restarts: 10,
    },

    {
      // Claude Code web UI — browser-based terminal for Claude Code sessions
      // with push notifications for long-running tasks.
      // See: https://github.com/wbopan/cui
      name: "cui",
      script: "/usr/bin/cui-server",  // Adjust to your install path
      interpreter: "/usr/bin/node",
      autorestart: true,
      max_restarts: 10,
    },

    {
      // CloudCLI — richer browser-based Claude Code UI with file explorer,
      // git integration, shell terminal, and MCP server management.
      // Complements CUI rather than replacing it.
      // See: https://github.com/siteboon/claudecodeui
      // See: docs/components/cloudcli.md for proxy config and gotchas.
      name: "cloudcli",
      cwd: "/home/YOUR_USER/apps/cloudcli",
      script: "npm",
      args: "start",
      env: {
        PORT: 3004,
        VITE_IS_PLATFORM: "true",   // Required — routing breaks without this
      },
      autorestart: true,
      max_restarts: 10,
    },

    {
      // Homelab operations MCP server — shell exec, file ops, and process
      // inspection for Claude agents via HTTP MCP transport (port 8282).
      // Desktop Commander (https://github.com/wonderwhy-er/DesktopCommanderMCP)
      // is the typical underlying package; run it in HTTP mode so LibreChat
      // and Claude Code can both reach it simultaneously.
      // Wired into agents via the MCP server config (see mcp-servers/README.md).
      name: "homelab-ops-mcp",
      cwd: "/home/YOUR_USER/apps/homelab-ops-mcp",
      script: "YOUR_START_COMMAND",
      env: {
        PORT: 8282,
      },
      autorestart: true,
      max_restarts: 10,
    },

    {
      // Agent panel — lightweight web UI for monitoring PM2 services,
      // viewing logs, and inspecting agent activity from a browser.
      name: "agent-panel",
      cwd: "/home/YOUR_USER/apps/agent-panel",
      script: "YOUR_START_COMMAND",
      env: {
        PORT: 3003,
      },
      autorestart: true,
      max_restarts: 10,
    },

    // =========================================================================
    // SCHEDULED JOBS (cron-triggered, run once then stop)
    // =========================================================================
    //
    // Pattern: autorestart: false + cron_restart = "run at schedule, don't loop"
    // PM2 starts the script at cron time, script runs to completion, PM2 marks
    // it as "stopped" until next cron trigger.

    {
      // Backup Docker appdata to NFS/remote storage
      // Stops containers, rsyncs appdata, restarts containers.
      name: "docker-stack-backup",
      script: "/home/YOUR_USER/scripts/docker-stack-backup.sh",
      interpreter: "bash",
      cron_restart: "0 1 * * *",   // Daily at 1:00 AM
      autorestart: false,
      watch: false,
    },

    {
      // Pull latest from all indexed git repos, re-embed for semantic search.
      // Keeps qmd index fresh with recent code and doc changes.
      name: "qmd-reindex",
      script: "/home/YOUR_USER/scripts/qmd-reindex.sh",
      interpreter: "bash",
      cron_restart: "0 5 * * *",   // Daily at 5:00 AM
      autorestart: false,
      watch: false,
    },

    {
      // Scan repos directory for collections not yet in the QMD index.
      // Repos matching keywords (claude, claudebox, mcp) are auto-added to
      // ~/.config/qmd/index.yml and a reindex is triggered. Everything else
      // is reported via push notification for manual review.
      // State is tracked — won't re-notify for the same pending set.
      name: "qmd-repo-check",
      script: "/home/YOUR_USER/scripts/check-qmd-repos.sh",
      interpreter: "bash",
      cron_restart: "0 9 * * *",   // Daily at 9:00 AM
      autorestart: false,
      watch: false,
    },

    {
      // Memory consolidation — 8-step pipeline: scan sessions, promote to
      // working tier, review, distill to permanent, expire stale, dedup.
      // Lock file at ~/.claude/memory-sync.lock prevents overlapping runs.
      // 10-minute timeout prevents runaway sessions.
      // See: claude-code/projects/memory-sync.md for the agent's instructions.
      name: "memory-sync",
      script: "/home/YOUR_USER/.claude/scripts/memory-sync.sh",
      interpreter: "bash",
      cron_restart: "0 4 * * *",   // Daily at 4:00 AM
      autorestart: false,
      watch: false,
    },

    {
      // Compact and optimize the memsearch vector database.
      // Milvus Lite accumulates fragmented segments over time — compaction
      // merges them and reclaims disk space. Runs 30 minutes after memory-sync
      // so newly promoted notes are included before compaction.
      name: "memsearch-compact",
      script: "/home/YOUR_USER/.claude/scripts/memsearch-compact.sh",
      interpreter: "bash",
      cron_restart: "30 4 * * *",  // Daily at 4:30 AM (after memory-sync at 4:00 AM)
      autorestart: false,
      watch: false,
    },

    {
      // Documentation health audit — drift, index, coverage, staleness, sanitization.
      // Opus model for editorial judgment. Report-first: findings go to
      // ~/.claude/memory/shared/doc-health-report.md, only index.md fixes auto-commit.
      // Lock file at ~/.claude/doc-health.lock prevents overlapping runs.
      // 20-minute timeout (Opus needs headroom for deeper reasoning).
      name: "doc-health",
      script: "/home/YOUR_USER/.claude/scripts/doc-health.sh",
      interpreter: "bash",
      cron_restart: "0 23 * * 0",   // Sundays at 11:00 PM
      autorestart: false,
      watch: false,
    },

    {
      // Check for updates to pinned dependencies (qmd, memsearch, Authelia,
      // Claude Code, etc). Alerts via ntfy if updates are available.
      name: "dep-update-check",
      script: "/home/YOUR_USER/scripts/check-dep-updates.sh",
      interpreter: "bash",
      cron_restart: "0 12 * * 3",  // Wednesdays at noon
      autorestart: false,
      watch: false,
    },

    {
      // Health check — RAM, disk, Docker containers, PM2 services, NFS mounts.
      // Sends alerts via ntfy if anything is unhealthy.
      name: "resource-monitor",
      script: "/home/YOUR_USER/scripts/check-resources.sh",
      interpreter: "bash",
      cron_restart: "0 */6 * * *", // Every 6 hours
      autorestart: false,
      watch: false,
    },

    {
      // Automated diagnostics — calls the agent panel's lightweight diagnostics
      // API on a schedule and sends push alerts on failures. Covers Docker
      // containers, PM2 services, NFS mounts, ports, TLS expiry, DNS, and
      // cross-host ping. The panel defines the checks; this job triggers them.
      // See: docs/components/diag-check.md
      name: "diag-check",
      script: "/home/YOUR_USER/scripts/run-diagnostics.sh",
      interpreter: "bash",
      cron_restart: "0 */6 * * *", // Every 6 hours
      autorestart: false,
      watch: false,
    },

    // =========================================================================
    // OPTIONAL: Issue/bug watchers
    // =========================================================================
    //
    // If you're tracking specific upstream issues that affect your stack,
    // you can add watchers that check GitHub issue status on a schedule.
    // Remove these if you don't need them.

    {
      // Check whether a tracked upstream GitHub issue is resolved.
      // Useful for issues that affect your stack and require a config
      // change or workaround once fixed. Alerts via ntfy.
      // Rename and update the script path to match the issue you're tracking.
      name: "qmd-issue-check",
      script: "/home/YOUR_USER/scripts/check-qmd-issue.sh",
      interpreter: "bash",
      cron_restart: "0 12 * * 1",  // Mondays at noon
      autorestart: false,
      watch: false,
    },

  ],
};
